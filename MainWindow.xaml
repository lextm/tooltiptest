<Window
    x:Class="ToolTipTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ToolTip Repro"
    Width="520"
    Height="470">
    <Window.Resources>
        <!-- A deliberately self-contained template. This separates a broken Fluent
             theme template from a broken Popup/portable text rendering path. -->
        <Style x:Key="ProbeToolTipStyle" TargetType="ToolTip">
            <Setter Property="Foreground" Value="Red" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="Blue" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="16" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel Margin="16">
        <Menu x:Name="MainMenu" DockPanel.Dock="Top" Margin="0,0,0,4" IsMainMenu="True">
            <MenuItem x:Name="FileMenuItem" Header="_File" SubmenuOpened="OnFileSubmenuOpened" SubmenuClosed="OnFileSubmenuClosed">
                <MenuItem x:Name="NewMenuItem" Header="_New" InputGestureText="Ctrl+N"
                          SubmenuOpened="OnNewSubmenuOpened"
                          SubmenuClosed="OnNewSubmenuClosed">
                    <MenuItem Header="_Project">
                        <MenuItem Header="_WPF Application" />
                        <MenuItem Header="_Class Library" />
                    </MenuItem>
                    <MenuItem Header="_File">
                        <MenuItem Header="_XAML View" />
                        <MenuItem Header="_C# Class" />
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="_Open..." InputGestureText="Ctrl+O" />
                <Separator />
            <MenuItem x:Name="RecentFilesMenuItem" Header="Recent _Files"
                      AutomationProperties.AutomationId="RecentFilesMenuItem"
                          SubmenuOpened="OnRecentFilesSubmenuOpened"
                          SubmenuClosed="OnRecentFilesSubmenuClosed">
                    <MenuItem Header="dummy" />
                </MenuItem>
                <Separator />
                <MenuItem Header="E_xit" IsEnabled="False" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGestureText="Ctrl+Z" />
                <MenuItem Header="_Redo" InputGestureText="Ctrl+Y" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About tooltiptest" />
            </MenuItem>
        </Menu>

        <StackPanel>
        <TextBlock x:Name="StatusText" Margin="0,0,0,12" Text="Hover the button below. Status will update here if ToolTipOpening fires." TextWrapping="Wrap" />

        <ToolBar x:Name="MainToolBar">
            <Button x:Name="PlainButton" Content="Plain Button" ToolTip="Plain button tooltip text" />
            <Separator />
            <Button x:Name="ServiceButton" Content="Service Button" />
            <Separator />
            <TextBlock VerticalAlignment="Center" Margin="4,0,6,0" Text="Theme:" />
            <ComboBox x:Name="ToolbarComboBox" Width="140" SelectedIndex="0"
                      ToolTip="Toolbar ComboBox dropdown"
                      DropDownOpened="OnToolbarComboBoxDropDownOpened"
                      DropDownClosed="OnToolbarComboBoxDropDownClosed">
                <ComboBoxItem Content="System default" />
                <ComboBoxItem Content="Light" />
                <ComboBoxItem Content="Dark" />
                <ComboBoxItem Content="High contrast" />
            </ComboBox>
        </ToolBar>

        <Button x:Name="ForceShowButton" Margin="0,16,0,0" Content="Force-show tooltip via code" Click="OnForceShowClick" />
        <Button x:Name="ForcePopupButton" Margin="0,8,0,0" Content="Force-show raw Popup" Click="OnForcePopupClick" />
        <Button x:Name="ProbeButton" Margin="0,8,0,0" Content="Probe explicit ToolTip template" />
        </StackPanel>
    </DockPanel>
</Window>
