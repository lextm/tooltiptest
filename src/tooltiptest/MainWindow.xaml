<Window
    x:Class="ToolTipTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ToolTipTest Runner" Width="800" Height="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
            <TextBlock Text="ToolTipTest Runner" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button x:Name="RunAllButton" Content="Run All" Width="80" Height="26" Margin="16,0,0,0" Click="OnRunAllClick"/>
            <Button x:Name="RunSelectedButton" Content="Run Selected" Width="100" Height="26" Margin="8,0,0,0" Click="OnRunSelectedClick"/>
            <Button x:Name="ToggleAllButton" Content="Toggle All" Width="80" Height="26" Margin="8,0,0,0" Click="OnToggleAllClick"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8">
            <StackPanel x:Name="TestListPanel"/>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="0,1,0,0" Background="#1E1E1E" MinHeight="120" MaxHeight="200">
            <ScrollViewer x:Name="ConsoleScroll" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="ConsoleOutput" FontFamily="Consolas" FontSize="11" Foreground="#D4D4D4" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
